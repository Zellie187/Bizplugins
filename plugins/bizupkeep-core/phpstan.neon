includes:
    - vendor/szepeviktor/phpstan-wordpress/extension.neon

parameters:

    level: 6

    paths:
        - includes

    tmpDir: .phpstan

    inferPrivatePropertyTypeFromConstructor: true

    ignoreErrors:
        # BIZUPKEEP_CORE_* path constants are define()'d at runtime by
        # bizupkeep-core.php / Bootstrap\Constants::register(); no stub
        # package can know about them ahead of time.
        - '#^Constant BIZUPKEEP_CORE_[A-Z_]+ not found\.$#'
