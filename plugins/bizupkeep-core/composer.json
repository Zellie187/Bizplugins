{
    "name": "bizupkeep/bizupkeep-core",
    "description": "BizUpKeep Core - the primary application framework for the BizUpKeep platform, built on top of the BizHub Framework",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": "^8.2",
        "php-di/php-di": "^7.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.9",
        "wp-coding-standards/wpcs": "^3.0",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "php-stubs/wordpress-stubs": "^6.9",
        "szepeviktor/phpstan-wordpress": "^1.3",
        "bizupkeep/bizhub-plugin": "dev-main"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../bizhub",
            "options": {
                "symlink": false,
                "versions": {
                    "bizupkeep/bizhub-plugin": "dev-main"
                }
            }
        }
    ],
    "autoload": {
        "psr-4": {
            "BizUpKeep\\Core\\": "includes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BizUpKeep\\Core\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
