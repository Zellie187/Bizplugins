<?xml version="1.0"?>
<ruleset name="BizHub Coding Standards">

    <description>
        BizHub WordPress Coding Standards
    </description>

    <arg value="sp"/>

    <file>plugins</file>

    <exclude-pattern>vendor/*</exclude-pattern>

    <rule ref="WordPress"/>

    <rule ref="PHPCompatibility">
        <properties>
            <property
                name="testVersion"
                value="8.2-"/>
        </properties>
    </rule>

</ruleset>