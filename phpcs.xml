<?xml version="1.0"?>
<ruleset name="BizHub">
    <description>
        BizHub uses PSR-4 autoloading and PSR-12 formatting (camelCase,
        spaces, class-name-matching filenames) rather than classic
        WordPress plugin conventions, so PSR12 is the base standard here.
        WordPress-specific security sniffs (escaping, nonce verification,
        SQL-injection prevention) are layered on top since this is still
        a WordPress plugin - but the full "WordPress" style ruleset
        (tabs, snake_case, Yoda conditions, "class-*.php" file naming)
        is not used, since it would fight the codebase's actual style.
    </description>

    <file>includes</file>
    <exclude-pattern>vendor/*</exclude-pattern>

    <rule ref="PSR12"/>

    <rule ref="WordPress.WP.I18n"/>
    <rule ref="WordPress.DB.PreparedSQL"/>
    <rule ref="WordPress.Security.NonceVerification"/>
    <rule ref="WordPress.Security.ValidatedSanitizedInput"/>

    <!--
        EscapeOutput is only meaningful where code actually echoes HTML
        (the Admin pages). Elsewhere it false-positives on ordinary
        variable usage - e.g. passing a value to an exception factory
        method - that has nothing to do with browser output.
    -->
    <rule ref="WordPress.Security.EscapeOutput">
        <include-pattern>includes/Admin/*</include-pattern>
    </rule>

    <rule ref="PHPCompatibility">
        <properties>
            <property name="testVersion" value="8.2-"/>
        </properties>
        <!--
            False positive on PHP 8.1+ enum methods: this sniff predates
            enums and misidentifies a valid $this inside an enum method as
            being outside an object context.
        -->
        <exclude name="PHPCompatibility.Variables.ForbiddenThisUseContexts.OutsideObjectContext"/>
    </rule>

    <!--
        WordPressDatabase is the single designated gatekeeper for $wpdb
        (see its class docblock) and routes every query through its own
        prepare()/query()/execute() wrapper. PreparedSQL only recognizes
        literal, inline $wpdb->prepare() calls, so it false-positives on
        this legitimate shared-wrapper abstraction.
    -->
    <rule ref="WordPress.DB.PreparedSQL">
        <exclude-pattern>includes/Framework/Database/Drivers/WordPressDatabase.php</exclude-pattern>
    </rule>
</ruleset>
